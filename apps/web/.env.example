OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL_A=mistralai/mistral-7b-instruct:free
OPENROUTER_MODEL_B=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_MODEL_C=google/gemma-7b-it:free

# Pro layer models (test/dev plan upgrade)
PRO_OPENROUTER_MODEL_A=openai/gpt-4.1-mini
PRO_OPENROUTER_MODEL_B=google/gemini-2.0-flash-001
PRO_OPENROUTER_MODEL_C=deepseek/deepseek-chat-v3-0324

RETRIEVAL_PROVIDER=web
WEB_RETRIEVAL_ENDPOINT=https://google.serper.dev/search
WEB_RETRIEVAL_API_KEY=
SERPER_API_KEY=
TAVILY_API_KEY=

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Founder admin (server API uses ADMIN_EMAIL; /admin page also needs NEXT_PUBLIC_ADMIN_EMAIL)
ADMIN_EMAIL=founder@example.com
NEXT_PUBLIC_ADMIN_EMAIL=founder@example.com

# Supabase (service role is server-only — never expose in client bundles)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
