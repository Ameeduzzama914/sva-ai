# Set to enable real GPT provider calls.
OPENAI_API_KEY=

# Set to enable real Gemini provider calls.
GEMINI_API_KEY=

# Set to enable real DeepSeek provider calls.
DEEPSEEK_API_KEY=

# Retrieval mode: "mock" or "web" (Serper.dev)
RETRIEVAL_PROVIDER=web

# Serper.dev endpoint + key for web retrieval mode
WEB_RETRIEVAL_ENDPOINT=https://google.serper.dev/search
WEB_RETRIEVAL_API_KEY=your_api_key_here
